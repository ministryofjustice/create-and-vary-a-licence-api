{
  "id": "pre-release-cases-submitted-approved",
  "name": "Pre release cases that are submitted or approved",
  "description": "Data products for Create and Vary a licence ",
  "metadata": {
    "author": "Caija Addai",
    "owner": "Caija Addai",
    "version": "1.0.5",
    "interactive": "true"
  },
  "datasource": [
    {
      "id": "cvl",
      "name": "cvl"
    }
  ],
  "dataset": [
    {
      "id": "licence-dataset",
      "name": "licence-dataset",
      "datasource": "cvl",
      "query": "SELECT l.noms_id AS nomis_number, concat(l.forename, ' ', l.surname) AS prisoner_name, l.crn, l.status_code FROM licence l WHERE l.status_code IN ('SUBMITTED', 'APPROVED') AND l.date_created >= '2026-06-15' AND (l.licence_start_date IS NOT NULL AND l.licence_start_Date >= CURRENT_DATE)'",
      "schema": {
        "field": [
          {
            "name": "nomis_number",
            "type": "string",
            "display": "NOMIS/Prison Number"
          },
          {
            "name": "prisoner_name",
            "type": "string",
            "display": "Name"
          },
          {
            "name": "crn",
            "type": "string",
            "display": "CRN"
          },
          {
            "name": "status_code",
            "type": "string",
            "display": "Licence Status"
          }
        ]
      }
    }
  ],
  "policy": [
    {
      "id": "access",
      "type": "access",
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "match": [
                "${role}",
                "ROLE_NOMIS_BATCHLOAD"
              ]
            }
          ]
        }
      ]
    }
  ],
  "report": [
    {
      "id": "pre-release-cases-submitted-approved",
      "name": "Pre release cases submitted or approved",
      "description": "Number of pre release CVL licences which are submitted or approved",
      "version": "1.0.0",
      "render": "HTML",
      "dataset": "$ref:licence-dataset",
      "feature": [
        {
          "type": "print"
        }
      ],
      "specification": {
        "template": "list",
        "field": [
          {
            "name": "$ref:nomis_number",
            "display": "NOMIS/Prison Number",
            "visible": "true",
            "sortable": true,
            "defaultsort": false
          },
          {
            "name": "$ref:prisoner_name",
            "display": "Name",
            "visible": "true",
            "sortable": true,
            "defaultsort": false
          },
          {
            "name": "$ref:crn",
            "display": "CRN",
            "visible": "true",
            "sortable": true,
            "defaultsort": false
          },
          {
            "name": "$ref:status_code",
            "display": "Licence Status",
            "visible": "true",
            "sortable": true,
            "defaultsort": false
          }
        ]
      },
      "summary": [
      ]
    }
  ]
}
